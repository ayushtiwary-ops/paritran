# Paritran environment template (SPEC section 4).
# Never commit .env. scripts/bootstrap_env.sh copies this file and replaces every CHANGE_ME.
DATABASE_URL=postgresql://paritran_app:CHANGE_ME@db:5432/paritran
POSTGRES_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=28800
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_TIMEOUT_SECONDS=30
# HF snapshot path inside the api container (INLEGALBERT_HOST_DIR is mounted read-only at /models/InLegalBERT).
INLEGALBERT_PATH=/models/InLegalBERT/snapshots/b5ecfed8ed6cf9d25a3cb8225a8c52f161f7401a
SEED=42
DEMO_MODE=false
SOUND_DEFAULT=off
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
OFFICER1_PASSWORD=CHANGE_ME
SUPERVISOR1_PASSWORD=CHANGE_ME
AUDITOR1_PASSWORD=CHANGE_ME
# Host directory holding the cached law-ai/InLegalBERT HF snapshot, bound read-only into the api container.
INLEGALBERT_HOST_DIR=/Users/aloo/.cache/huggingface/hub/models--law-ai--InLegalBERT
