# Paritran web image (SPEC section 2: web listens on 80 in-container,
# published as 8081 on the host by docker-compose.yml).
# Build context MUST be the repository root, e.g. in docker-compose.yml:
#   build:
#     context: .
#     dockerfile: infra/docker/Dockerfile.web
# because this file copies both frontend/ and infra/docker/nginx.conf.

# Stage 1: build the Vite bundle. Fonts are bundled from @fontsource
# packages, so the resulting image serves everything offline (no CDN).
FROM node:22-alpine AS build
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci
COPY frontend/ ./
RUN npm run build

# Stage 2: serve the static build with nginx.
FROM nginx:1.27-alpine
COPY infra/docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
