{
  "uid": "paritran-observability",
  "title": "Paritran Observability",
  "description": "Milestone 8 (SPEC 12): API traffic, latency, errors, and paritran_* custom metrics (runs, F9 verdicts, SPEC 8.4 audit chain head anchor). All series come from the Prometheus scrape of api:8000/metrics.",
  "tags": ["paritran"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "editable": true,
  "graphTooltip": 1,
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "refresh": 1,
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" }
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API scrape target up",
      "description": "1 when Prometheus can scrape api:8000/metrics.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"api\"}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pipeline runs started",
      "description": "paritran_runs_total by requested generator (POST /api/intake/run). Counter resets on API restart; the panel shows the current counter value, not an all-time total.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 5, "x": 4, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (generator) (paritran_runs_total{job=\"api\"})",
          "legendFormat": "{{generator}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "noValue": "0 (no run since API start)",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "F9 verdicts (since API start)",
      "description": "paritran_f9_verdicts_total: one increment per gated claim when a run's F9 result lands. Labelled by verdict and by the generator the result was actually produced with (an ollama request that degraded to the stub counts under the stub's name).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 7, "x": 9, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (verdict) (paritran_f9_verdicts_total{job=\"api\"})",
          "legendFormat": "{{verdict}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "noValue": "0 (no F9 result since API start)",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "PASSED" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "WITHHELD" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Audit chain head (SPEC 8.4 anchor)",
      "description": "paritran_audit_chain_head_info: head hash and seq of the latest audit_log row observed by the API process (out-of-band anchor). Refreshed on every audit append and primed from the last audit row at startup. Absent until the API has observed at least one row.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "paritran_audit_chain_head_info{job=\"api\"}",
          "legendFormat": "seq {{seq}}: {{head_hash}}",
          "instant": true,
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "noValue": "no chain head observed yet",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request rate by handler",
      "description": "sum by (handler) of rate(http_requests_total). The /metrics scrape itself is excluded to keep application traffic readable.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (handler) (rate(http_requests_total{job=\"api\", handler!=\"/metrics\"}[$__rate_interval]))",
          "legendFormat": "{{handler}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 8, "showPoints": "never" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "API latency p50 / p95",
      "description": "histogram_quantile over http_request_duration_seconds buckets (prometheus-fastapi-instrumentator). This histogram has deliberately few buckets, so quantiles are bucket-resolution estimates, not exact percentiles; the in-app status widget's p50/p95 come from the API's own latency ring buffer instead.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"api\", handler!=\"/metrics\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"api\", handler!=\"/metrics\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5, "showPoints": "never" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Error rate (5xx and 4xx)",
      "description": "rate(http_requests_total) filtered by the instrumentator's grouped status label. 4xx is context (auth failures, rate limits); 5xx is the alert-worthy line.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{job=\"api\", status=\"5xx\"}[$__rate_interval]))",
          "legendFormat": "5xx",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "refId": "B",
          "expr": "sum(rate(http_requests_total{job=\"api\", status=\"4xx\"}[$__rate_interval]))",
          "legendFormat": "4xx",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "5xx" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "4xx" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "In-progress requests by handler",
      "description": "http_requests_inprogress gauge (Milestone 8 enables it on the instrumentator). Long-lived SSE streams (/api/stream/*) legitimately hold this above zero.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (handler) (http_requests_inprogress{job=\"api\"})",
          "legendFormat": "{{handler}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 15, "showPoints": "never", "stacking": { "mode": "normal", "group": "A" } },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ]
}
